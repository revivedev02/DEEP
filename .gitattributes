# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.env  text eol=lf

# Binary — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
