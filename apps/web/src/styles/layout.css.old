/* ── Layout shells ── */
@layer components {
  .layout-root {
    display: flex;
    height: 100%;
    width: 100%;
    overflow: hidden;
    background: var(--bg-canvas);
    padding: 8px;
    gap: 8px;
  }

  /* ── Channel Sidebar — floats on canvas, no border ── */
  .channel-sidebar {
    display: flex;
    flex-direction: column;
    width: 240px;
    min-width: 240px;
    background: transparent;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* ── Chat Card ── */
  .chat-card {
    display: flex;
    flex: 1;
    overflow: hidden;
    background: var(--card-bg);
    border-radius: var(--card-radius);
    border: none;
    min-width: 0;
  }

  /* ── Channel header — sits at top of card, no bottom border ── */
  .channel-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    height: 56px;
    min-height: 56px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(var(--separator-rgb) / 0.15);
  }
  .channel-header-name {
    @apply text-[15px] font-semibold text-text-normal;
  }
  .channel-header-topic {
    @apply hidden md:flex items-center gap-1 text-[13px] text-text-muted
           pl-3 ml-2 border-l border-separator truncate;
  }

  /* ── Main content inside card ── */
  .main-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  /* ── Canvas header bar — sits above the card on the canvas ── */
  .canvas-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 12px;
    height: 48px;
    min-height: 48px;
    flex-shrink: 0;
  }

  /* Icon buttons on the canvas — subtle, no bg box */
  .canvas-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 120ms ease, background 120ms ease,
                transform 150ms cubic-bezier(0.34, 1.56, 0.64, 1);
    border: none;
    background: none;
  }
  .canvas-icon-btn:hover {
    color: var(--text-normal);
    background: var(--bg-hover);
    transform: scale(1.12);
  }
  .canvas-icon-btn:active {
    transform: scale(0.88);
    transition-duration: 60ms;
  }
  .canvas-icon-btn.active {
    color: var(--text-normal);
    background: rgba(var(--brand-rgb) / 0.15);
  }
  .canvas-icon-btn.active:hover {
    transform: scale(1.12);
  }

  /* ── Sidebar section title ── */
  .sidebar-section-title {
    @apply flex items-center gap-1 px-3 mt-4 mb-1
           font-semibold uppercase tracking-wider text-text-muted;
    font-size: 11.5px;
  }

  /* ── Channel item — filled pill ── */
  .channel-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 1px 8px;
    padding: 8px 10px;
    border-radius: 8px;
    font-size: 15px;
    color: var(--text-muted);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease, transform 120ms ease;
  }
  .channel-item:hover {
    background: var(--bg-hover);
    color: var(--text-normal);
    transform: translateX(2px);
  }
  .channel-item.active {
    background: rgba(var(--brand-rgb) / 0.15);
    color: var(--text-normal);
    font-weight: 500;
    transform: translateX(0);  /* active items don’t shift */
  }
  .channel-item .channel-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.6;
  }
  .channel-item.active .channel-icon {
    opacity: 1;
  }

  /* ── User Panel (sidebar footer) ── */
  .user-panel {
    @apply flex items-center gap-2 px-2 py-2 mt-auto
           hover:bg-bg-modifier transition-colors duration-150 cursor-pointer
           rounded-lg mx-2 mb-1;
  }
  .avatar {
    @apply relative flex-shrink-0;
  }
  .avatar img, .avatar-placeholder {
    @apply w-8 h-8 rounded-full object-cover;
  }
  .avatar-placeholder {
    @apply flex items-center justify-center bg-brand text-white text-sm font-semibold w-8 h-8 rounded-full;
  }
  .status-dot {
    @apply absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full;
    border: 2px solid var(--bg-canvas);
  }
  .status-dot.online  { @apply bg-status-green; }
  .status-dot.offline { @apply bg-text-muted; }

  /* ── Members Panel — borderless, on canvas ── */
  .members-panel {
    display: flex;
    flex-direction: column;
    width: 220px;
    min-width: 220px;
    background: transparent;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 12px 0;
    flex-shrink: 0;
  }
  .member-section-title {
    padding: 4px 16px 6px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .member-item {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 1px 8px;
    padding: 7px 10px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 100ms ease;
  }
  .member-item:hover {
    background: var(--bg-hover);
  }
  .member-name {
    font-size: 13.5px;
    color: var(--text-muted);
  }
  .member-item:hover .member-name {
    color: var(--text-normal);
  }

  /* ── Voice Coming Soon ── */
  .coming-soon-pane {
    @apply flex flex-col items-center justify-center flex-1 gap-6 select-none;
  }
  .coming-soon-icon-ring {
    @apply relative flex items-center justify-center w-32 h-32;
  }
}

/* ── Members slide-in ── */
@keyframes members-slide-in {
  from { opacity: 0; transform: translateX(16px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ── Mobile: hide sidebar, full-width card ── */
@media (max-width: 768px) {
  .layout-root { padding: 0; gap: 0; }
  .channel-sidebar { display: none; }
  .chat-card { border-radius: 0; }
  .members-panel { display: none; }
}
