# ─────────────────────────────────────────────────────────────────────────────
# DEEP Server — Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production     # "development" or "production"
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local Docker:  "postgresql://postgres:deeppass@localhost:5432/deep"
# Supabase:      found in Project Settings → Database → Connection String (URI)
# Neon:          found in Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@host:5432/deep?sslmode=require"

# Optional: Prisma connection pool size per worker (default 9)
# With 4 CPU cores → 4 workers × 9 = 36 total DB connections
DB_POOL_SIZE=9

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for pm2 cluster mode so socket events sync across workers.
# Local Docker:  "redis://localhost:6379"
# Upstash:       "redis://:<password>@<host>:<port>"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SHORTID="admin_init"

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
