# ─────────────────────────────────────────────────────────────────────────────
# DEEP Server — Environment Variables
#
# On Railway: DATABASE_URL and REDIS_URL are AUTO-SET when you add
# the PostgreSQL and Redis service plugins. You only need to set the
# variables below manually.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000             # Railway overrides this automatically — leave as 3000

# ── Database ─────────────────────────────────────────────────────────────────
# Railway:   Add a "PostgreSQL" plugin → DATABASE_URL is set automatically ✅
# Local dev: Use Docker → postgresql://postgres:deeppass@localhost:5432/deep
#            or Neon free tier → https://neon.tech (no credit card needed)
DATABASE_URL="postgresql://user:password@host:5432/deep?sslmode=require"
DB_POOL_SIZE=9

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway:   Add a "Redis" plugin → REDIS_URL is set automatically ✅
# Local dev: Use Docker → redis://localhost:6379
# Optional:  If not set, server falls back to single-process mode gracefully
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this in Railway → Variables tab
JWT_SECRET="replace-with-long-random-string"

# ── Admin ─────────────────────────────────────────────────────────────────────
# The short ID used to log in as admin. Set once, never change.
ADMIN_SHORTID="admin_init"

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
