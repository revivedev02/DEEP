{
  "name": "@pdl/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":        "node --env-file=.env --import tsx/esm src/index.ts",
    "dev:watch":  "tsx watch --env-file=.env src/index.ts",
    "build":      "prisma generate && tsc",
    "start":      "node dist/index.js",
    "db:push":    "node --env-file=.env --import tsx/esm node_modules/prisma/build/index.js db push",
    "db:generate":"prisma generate",
    "db:seed":    "node --env-file=.env --import tsx/esm prisma/seed.ts",
    "db:studio":  "prisma studio"
  },
  "dependencies": {
    "@fastify/compress": "7",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^7.7.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.15.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.10.1",
    "nanoid": "^3.3.7",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prisma": "^5.15.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  }
}
